@model IEnumerable<Mission08_Team0109.Models.TaskItem>

@{
    ViewData["Title"] = "Quadrants";

    // Only show incomplete tasks
    var tasks = Model.Where(t => !t.Completed).ToList();

    var q1 = tasks.Where(t => t.Quadrant == 1).ToList();
    var q2 = tasks.Where(t => t.Quadrant == 2).ToList();
    var q3 = tasks.Where(t => t.Quadrant == 3).ToList();
    var q4 = tasks.Where(t => t.Quadrant == 4).ToList();
}

<h2 class="mb-4">Stephen Covey Task Matrix</h2>

<div class="container">
    <div class="row g-4">

        <!-- Quadrant I -->
        <div class="col-md-6">
            <div class="card h-100 border-danger">
                <div class="card-header bg-danger text-white fw-bold">
                    Quadrant I — Important / Urgent
                </div>
                <div class="card-body">
                    @if (!q1.Any())
                    {
                        <p class="text-muted">No tasks.</p>
                    }
                    else
                    {
                        foreach (var t in q1)
                        {
                            <div class="border rounded p-2 mb-2">
                                <strong>@t.TaskName</strong><br />
                                <small>Due: @(t.DueDate?.ToString("MMM d, yyyy") ?? "—")</small>

                                <div class="mt-2 d-flex gap-2">
                                    <form asp-action="Complete" method="post">
                                        <input type="hidden" name="id" value="@t.TaskId" />
                                        <button class="btn btn-sm btn-outline-success">
                                            Complete
                                        </button>
                                    </form>

                                    <form asp-action="Delete" method="post">
                                        <input type="hidden" name="id" value="@t.TaskId" />
                                        <button class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Delete this task?');">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Quadrant II -->
        <div class="col-md-6">
            <div class="card h-100 border-success">
                <div class="card-header bg-success text-white fw-bold">
                    Quadrant II — Important / Not Urgent
                </div>
                <div class="card-body">
                    @if (!q2.Any())
                    {
                        <p class="text-muted">No tasks.</p>
                    }
                    else
                    {
                        foreach (var t in q2)
                        {
                            <partial name="~/Views/Home/Quadrants.cshtml" />
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Quadrant III -->
        <div class="col-md-6">
            <div class="card h-100 border-warning">
                <div class="card-header fw-bold">
                    Quadrant III — Not Important / Urgent
                </div>
                <div class="card-body">
                    @if (!q3.Any())
                    {
                        <p class="text-muted">No tasks.</p>
                    }
                    else
                    {
                        foreach (var t in q3)
                        {
                            <div class="border rounded p-2 mb-2">
                                <strong>@t.TaskName</strong>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Quadrant IV -->
        <div class="col-md-6">
            <div class="card h-100 border-secondary">
                <div class="card-header text-white bg-secondary fw-bold">
                    Quadrant IV — Not Important / Not Urgent
                </div>
                <div class="card-body">
                    @if (!q4.Any())
                    {
                        <p class="text-muted">No tasks.</p>
                    }
                    else
                    {
                        foreach (var t in q4)
                        {
                            <div class="border rounded p-2 mb-2">
                                <strong>@t.TaskName</strong>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
</div>